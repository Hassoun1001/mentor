# --- Application ---
MENTOR_ENV=development
MENTOR_LOG_LEVEL=INFO
MENTOR_API_PREFIX=/api/v1
MENTOR_CORS_ORIGINS=http://localhost:5173

# --- Database (TimescaleDB / Postgres) ---
MENTOR_DB_HOST=localhost
MENTOR_DB_PORT=5432
MENTOR_DB_NAME=mentor
MENTOR_DB_USER=mentor
MENTOR_DB_PASSWORD=change-me

# --- Auth (single-user) ---
# Password hash for the single user. Generate with: python -m mentor.cli.hash_password
MENTOR_AUTH_USERNAME=mentor
MENTOR_AUTH_PASSWORD_HASH=
MENTOR_JWT_SECRET=please-generate-a-32-byte-secret
MENTOR_JWT_TTL_HOURS=12

# --- Autonomous learning loop ---
# When true, an in-process scheduler ingests fresh bars, predicts, resolves due
# predictions, and periodically retrains + promotes the best model. Enable this
# on an always-on host (e.g. the Oracle VM) so the system keeps learning 24/7.
MENTOR_LOOP_ENABLED=false
MENTOR_LOOP_SYMBOL=EURUSD
MENTOR_LOOP_TIMEFRAME=1h
MENTOR_LOOP_INGEST_INTERVAL_MINUTES=60
MENTOR_LOOP_PREDICT_INTERVAL_MINUTES=60
MENTOR_LOOP_RESOLVE_INTERVAL_MINUTES=15
MENTOR_LOOP_RETRAIN_INTERVAL_HOURS=168

# --- Deploy (public HTTPS via Caddy; see ORACLE_DEPLOY.md) ---
# MENTOR_DOMAIN=tradementor.duckdns.org

# --- LLM (server-side only, never expose to browser) ---
ANTHROPIC_API_KEY=
MENTOR_LLM_MODEL=claude-opus-4-8

# --- Market data adapters (Phase 1+) ---
TWELVE_DATA_API_KEY=
ALPHA_VANTAGE_API_KEY=
OANDA_API_KEY=
OANDA_ACCOUNT_ID=

# --- News & calendar (Phase 4) ---
NEWSAPI_KEY=
FINNHUB_KEY=
MARKETAUX_KEY=
